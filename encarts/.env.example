# ============================================================
# ENVIRONMENT CONFIGURATION - ENCARTS DIGITAL SYSTEM
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commit o arquivo .env no repositório Git
# ============================================================

# ============================================================
# BANCO DE DADOS (MySQL/MariaDB)
# ============================================================
# Hostinger: use os dados do painel hPanel > Banco de Dados MySQL
DB_HOST=localhost
DB_NAME=u624766619_encartes
DB_USER=u624766619_encartes
DB_PASS=sua_senha_aqui
DB_CHARSET=utf8mb4

# ============================================================
# CLERK AUTHENTICATION
# ============================================================
# Obtenha estas chaves em https://dashboard.clerk.com
# Vá em: API Keys > Keys
# ============================================================

# Chave pública (usada no frontend)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave secreta (usada no backend para validação JWT)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret do webhook (para validar webhooks do Clerk)
# Obtenha em: Webhooks > Escolha o endpoint > Signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL JWKS do Clerk (padrão, não precisa alterar)
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# Issuer do Clerk (domínio da sua instância Clerk)
# Ex: https://seu-dominio.clerk.accounts.dev
CLERK_ISSUER=https://trusted-primate-39.clerk.accounts.dev

# ============================================================
# APLICAÇÃO
# ============================================================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://seudominio.com.br/encarts

# ============================================================
# UPLOAD
# ============================================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================================
# TIMEZONE
# ============================================================
TIMEZONE=America/Sao_Paulo
