# Configurações do Banco de Dados MySQL
# Para Hostinger, use as credenciais fornecidas no painel de controle
DB_HOST=localhost
DB_NAME=u624766619_encartes
DB_USER=u624766619_encartes
DB_PASS=Pt190912!@#
DB_CHARSET=utf8mb4

# Configurações da Aplicação
APP_NAME=Encarts Digital System
APP_URL=https://seudominio.com
APP_ENV=production

# Sessão (em horas)
SESSION_LIFETIME=24

# Upload (tamanho máximo em bytes - 5MB)
MAX_UPLOAD_SIZE=5242880

# Rate Limiting (tentativas por IP em minutos)
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_WINDOW=15
