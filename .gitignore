```
# Environment and config files
.env
.env.local
.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# PHP specific
*.php~
phpunit.xml.dist
composer.lock

# Uploads directory (if it contains temporary files)
flyersaas/assets/uploads/*
!flyersaas/assets/uploads/.htaccess

# Database migration backups
flyersaas/database/migrations/*.sql.bak
flyersaas/database/migrations/*_backup.sql

# Installation files
flyersaas/install.php
```