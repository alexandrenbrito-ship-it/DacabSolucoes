# Prevenir execução de PHP na pasta de uploads
<FilesMatch "\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Forçar download de arquivos em vez de execução
<FilesMatch "\.(exe|sh|bat|cmd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Definir tipo de conteúdo para imagens
<IfModule mod_mime.c>
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/gif .gif
    AddType image/webp .webp
</IfModule>
